Dialogue: 0,0:00:17.45,0:00:23.20,Top,,0,0,0,,그 누구도 못가본 길
Dialogue: 0,0:00:17.45,0:00:26.93,Bottom,,0,0,0,,屈함없이 우리 왔네
Dialogue: 0,0:00:23.20,0:00:30.63,Top,,0,0,0,,이 나라를 목숨보다
Dialogue: 0,0:00:26.93,0:00:34.23,Bottom,,0,0,0,,더 사랑하기에
Dialogue: 0,0:00:30.63,0:00:37.97,Top,,0,0,0,,{\fn思源宋體}雪{\fn}寒風도 砲火속도
Dialogue: 0,0:00:34.23,0:00:41.81,Bottom,,0,0,0,,피로 헤쳐 勝利했고
Dialogue: 0,0:00:37.97,0:00:45.47,Top,,0,0,0,,맨손으로 빈터에도
Dialogue: 0,0:00:41.81,0:00:49.19,Bottom,,0,0,0,,樂園 세웠네
Dialogue: 0,0:00:45.47,0:00:53.01,Top,,0,0,0,,그렇게 强하다
Dialogue: 0,0:00:49.19,0:00:56.55,Bottom,,0,0,0,,우리는 朝鮮사람
Dialogue: 0,0:00:53.01,0:01:03.97,Top,,0,0,0,,代代孫孫 屈할줄을 모른다
Dialogue: 0,0:00:56.55,0:01:07.63,Bottom,,0,0,0,,보여주리라
Dialogue: 0,0:01:03.97,0:01:11.39,Top,,0,0,0,,그 氣像 百倍해
Dialogue: 0,0:01:07.63,0:01:20.97,Bottom,,0,0,0,,이 朝鮮이 億年 솟아 强大함을
Dialogue: 0,0:01:11.39,0:01:27.97,Top,,0,0,0,,追憶깊은 가슴들과
Dialogue: 0,0:01:20.97,0:01:31.64,Bottom,,0,0,0,,家庭들엔 살아있네
Dialogue: 0,0:01:27.97,0:01:35.23,Top,,0,0,0,,아낌없이 生을 바친
Dialogue: 0,0:01:31.64,0:01:38.97,Bottom,,0,0,0,,先烈들 그 넋이
Dialogue: 0,0:01:35.23,0:01:42.72,Top,,0,0,0,,그들처럼 運命걸고
Dialogue: 0,0:01:38.97,0:01:46.29,Bottom,,0,0,0,,우리 尊嚴 지켜가고
Dialogue: 0,0:01:42.72,0:01:50.24,Top,,0,0,0,,쓰러져도 우리의 길
Dialogue: 0,0:01:46.29,0:01:53.79,Bottom,,0,0,0,,끌까지 가네
Dialogue: 0,0:01:50.24,0:01:57.49,Top,,0,0,0,,그렇게 强하다
Dialogue: 0,0:01:53.79,0:02:01.16,Bottom,,0,0,0,,우리는 朝鮮사람
